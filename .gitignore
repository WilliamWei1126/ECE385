###########
#  Vitis  #
###########

# When opening a Vitis project for the first time:
# - Make a new workspace at the project directory (ends in _sdk)
# - File > Import
# - Eclipse workspace or zip file
# - Open the same workspace directory again (ends in _sdk)
# - Select all the projects
# - Uncheck "Copy projects into workspace"
# - Finish
# - Update Hardware Specification (from the .xsa file in the corresponding Vivado project)

#Build Results
**/*_sdk/*.o
**/*_sdk/*.elf
**/*_sdk/*.d
**/*_sdk/*.del
**/*_sdk/export/

#Workspace files
**/*_sdk/.analytics
**/*_sdk/.metadata
**/*_sdk/RemoteSystemsTempFiles/
**/*_sdk/**/_ide/*

#Generate HW files
**/*_sdk/*/hw/**/*
!**/*_sdk/*/hw/*.xsa

#Generated BSP files
**/*_sdk/**/*bsp/ps7_cortexa9_*
**/*_sdk/**/*bsp/psu_cortexa53_*
**/*_sdk/**/*bsp/psu_cortexr5_*
**/*_sdk/**/*bsp/psu_pmu_*

#BSP Export (listed contents separately because "export" is a common name)
**/*_sdk/*/export/

Makefile
**/*_sdk/*.mk

#log files
**/*_sdk/*.log

#Eclipse files
**/*_sdk/.buildpath
**/*_sdk/.settings/org.eclipse.cdt.core.prefs


