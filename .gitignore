# =========================
**/.Xil/
**/*.cache/
**/*.hw/
**/*.ip_user_files/
**/*.runs/
**/*.sim/
**/*.gen/
**/*.jou
**/*.log
**/*.str
**/*.dmp
**/*.wdb

# Per-user / generated project state

# Generated checkpoints / implementation outputs
**/*.dcp

# Optional: ignore BD-generated child-IP artifacts
# Keep this only if your repo works fine after a clean clone + open project + regenerate output products
**/*.srcs/sources_1/bd/*/ip/

# =========================
# OS / editor noise
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/

# keep all Vivado project files everywhere
!*.xpr

# =========================
# Lab6.1: ignore everything except selected source folders
# =========================
/Lab6/Lab6.1/**

# keep required parent folders so Git can descend into them
!/Lab6/Lab6.1/sdk/
!/Lab6/Lab6.1/sdk/mb_blinky/
!/Lab6/Lab6.1/pin_assignment/
!/Lab6/Lab6.1/design_source/

# keep the actual folders you want
!/Lab6/Lab6.1/sdk/mb_blinky/src/
!/Lab6/Lab6.1/sdk/mb_blinky/src/**
!/Lab6/Lab6.1/pin_assignment/**
!/Lab6/Lab6.1/design_source/**